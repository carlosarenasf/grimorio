# Backend — variables de entorno (NO subir el .env real; solo este ejemplo).
# En producción se definen en el panel de Render, nunca en el repo.

# Postgres (Neon). Incluye ?sslmode=require al final.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Secreto de firma de sesión. Genera uno propio: openssl rand -hex 32
SESSION_SECRET=

# Origen EXACTO del frontend permitido por CORS (sin barra final).
CORS_ORIGIN=https://grimorio-frontend.onrender.com

# Producción: activa cookie SameSite=None; Secure automáticamente.
NODE_ENV=production

# PORT lo inyecta Render automáticamente; en local por defecto 3000.
# PORT=3000
